<!-- intl-tel-input: country-code dropdown for the mobile field -->
<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/intl-tel-input@29.0.5/dist/css/intlTelInput.css"
/>
<script src="https://cdn.jsdelivr.net/npm/intl-tel-input@29.0.5/dist/js/intlTelInput.min.js"></script>
<style>
  /* Phone widget spans full width like the other inputs */
  .iti {
    width: 100%;
  }
  /* Country code shown next to the flag: match the number input (white, same size) */
  #add-user-modal .iti__selected-country,
  #add-user-modal .iti__selected-dial-code {
    color: #fff;
    font-size: 1.4rem;
  }
</style>

<div class="modal-wrapper" id="add-user-modal">
  <div class="modal">
    <a href="#" onclick="closeModal()" class="modal-close">+</a>
    <div class="modal-title">
      <h2>Create New User</h2>
    </div>
    <div class="modal-body">
      <form
        id="add-user-form"
        method="post"
        action="/users"
        enctype="multipart/form-data"
      >
        <input type="text" placeholder="Enter name" name="name" />
        <p class="error name-error"></p>
        <input type="text" placeholder="Enter age" name="age" />
        <p class="error age-error"></p>
        <input type="text" placeholder="Enter email" name="email" />
        <p class="error email-error"></p>
        <input type="tel" id="mobile" placeholder="Enter mobile" name="mobile" />
        <p class="error mobile-error"></p>
        <input type="password" placeholder="Enter password" name="password" />
        <p class="error password-error"></p>
        <input type="file" name="avatar" />
        <p class="error avatar-error"></p>

        <p class="error general-error"></p>

        <input type="submit" value="Submit" />
      </form>
    </div>
  </div>
</div>
<script>
  const modal = document.querySelector("#add-user-modal");
  const form = document.querySelector("#add-user-form");

  // Country-code dropdown on the mobile field.
  // separateDialCode shows the +code next to the flag; user types only the local number.
  const phoneInputField = form.querySelector('input[name="mobile"]');
  const iti = window.intlTelInput(phoneInputField, {
    initialCountry: "bd",
    separateDialCode: true,
    loadUtils: () =>
      import(
        "https://cdn.jsdelivr.net/npm/intl-tel-input@29.0.5/dist/js/utils.js"
      ),
  });


  function closeModal() {
    modal.style.display = "none";
  }

  function openModal() {
    modal.style.display = "block";
  }

  function clearErrors() {
    form.querySelectorAll("p.error").forEach((el) => {
      el.textContent = "";
      el.classList.remove("show");
    });
    form.querySelectorAll("input").forEach((el) => el.classList.remove("error"));
  }

  function setFieldError(fieldName, msg) {
    const errorEl = form.querySelector(`.${fieldName}-error`);
    const inputEl = form.querySelector(`[name="${fieldName}"]`);
    if (errorEl) {
      errorEl.textContent = msg || "";
      errorEl.classList.toggle("show", !!msg);
    }
    if (inputEl) {
      inputEl.classList.toggle("error", !!msg);
    }
  }

  function displayErrors(errors) {
    setFieldError("name", errors?.name?.msg);
    setFieldError("age", errors?.age?.msg);
    setFieldError("email", errors?.email?.msg);
    setFieldError("mobile", errors?.mobile?.msg);
    setFieldError("password", errors?.password?.msg);
    setFieldError("avatar", errors?.avatar?.msg);
    const generalEl = form.querySelector(".general-error");
    if (errors?.general?.msg) {
      generalEl.textContent = errors.general.msg;
      generalEl.classList.add("show");
    }
  }

  // Build the full international number (E.164), e.g. +8801712345678.
  function getFullNumber() {
    const fromLib = iti.getNumber();
    if (fromLib) return fromLib;
    // Fallback if the formatter has not loaded yet: read the dial code from the DOM.
    const dialEl = document.querySelector(
      "#add-user-modal .iti__selected-dial-code"
    );
    const dial = dialEl ? dialEl.textContent.replace(/\D/g, "") : "";
    const local = phoneInputField.value.replace(/\D/g, "");
    return dial || local ? "+" + dial + local : "";
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    clearErrors();

    phoneInputField.value = getFullNumber();

    try {
      const response = await fetch("/users", {
        method: "POST",
        body: new FormData(form),
      });
      const data = await response.json();
      if (data.success) {
        Toastify({
          text: "User added successfully!",
          duration: 3000,
          gravity: "top",
          position: "right",
          style: { background: "#4CAF50" },
        }).showToast();
        closeModal();
        setTimeout(() => location.reload(), 1500);
      } else {
        displayErrors(data.errors);
      }
    } catch (err) {
      // Logs the real reason (network drop, server restart, bad JSON) to the console.
      console.error("User create failed:", err);
      const generalEl = form.querySelector(".general-error");
      generalEl.textContent = "Something went wrong. Please try again.";
      generalEl.classList.add("show");
    }
  });
</script>
